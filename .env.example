# Copy this file to .env and fill in your SIMKL client id.
SIMKL_CLIENT_ID=

# Path to the local SQLite database file used to cache confirmed SIMKL IDs
# and to let a job be resumed by ID after a server restart. The file (and
# its parent folder) is created automatically on first use.
DB_PATH=data/tvtime_simkl.sqlite3

# Minimum delay between SIMKL API requests, and request timeout, in milliseconds.
SIMKL_API_DELAY_MS=110
SIMKL_API_TIMEOUT_MS=20000

# Web server bind address and port.
HOST=127.0.0.1
PORT=8080
